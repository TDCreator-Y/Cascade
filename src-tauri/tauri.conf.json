{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cascade",
  "version": "1.0.0",
  "identifier": "com.cascade.proxy",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Cascade",
        "width": 820,
        "height": 800,
        "resizable": true,
        "minWidth": 480,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' blob: 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: blob: https://asset.localhost; connect-src ipc: http://ipc.localhost https://ipc.localhost ws://localhost wss://localhost http://localhost https://localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
